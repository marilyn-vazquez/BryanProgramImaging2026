def find(condition):
    """
    Finds the indices of elements that satisfy a given condition.

    Parameters
    ----------
    condition : array_like or bool
        Boolean array or condition expression to evaluate.

    Inputs
    ------
    - Array or conditional expression evaluated via `np.nonzero`.

    Outputs
    -------
    - tuple of ndarrays: Indices of elements where the condition is true.
    """
    return np.nonzero(condition)


def biImg_by_threshold_leq(img, threshold):
    """
    Converts an image into a binary image using a less-than-or-equal threshold rule.

    Parameters
    ----------
    img : numpy.ndarray
        Input image array.
    threshold : float or int
        Threshold cutoff value.

    Inputs
    ------
    - Pixel intensity array `img`.

    Outputs
    -------
    - numpy.ndarray: Binarized image array.
    """
    output_img = np.copy(img)
    output_img[find(img <= threshold)], output_img[find(img > threshold)] = 0, 1
    return output_img


def biImg_by_threshold_geq(img, threshold):
    """
    Converts an image into a binary image using a greater-than-or-equal threshold rule.

    Parameters
    ----------
    img : numpy.ndarray
        Input image array.
    threshold : float or int
        Threshold cutoff value.

    Inputs
    ------
    - Pixel intensity array `img`.

    Outputs
    -------
    - numpy.ndarray: Binarized image array.
    """
    output_img = np.copy(img)
    output_img[find(img >= threshold)], output_img[find(img < threshold)] = 0, 1
    return output_img


@nb.jit(nopython=True)
def erosion(input_np_array, input_list_of_points, minimal_pixel_value=0):
    """
    Performs morphological erosion on a 2D array using Numba compilation and point offsets.

    Parameters
    ----------
    input_np_array : numpy.ndarray
        2D input array to erode.
    input_list_of_points : list of numpy.ndarray or tuple
        Structuring element offsets.
    minimal_pixel_value : int or float, optional
        Minimum background value. Default is 0.

    Inputs
    ------
    - 2D image matrix and kernel points.

    Outputs
    -------
    - numpy.ndarray: Eroded 2D array.
    """
    shape = input_np_array.shape
    output = np.zeros(shape)
    for i in range(shape[0]):
        for j in range(shape[1]):
            if input_np_array[i, j] == minimal_pixel_value:
                output[i, j] = minimal_pixel_value
                continue
            vals = []
            for k in range(len(input_list_of_points)):
                m, n = i - input_list_of_points[k][1], j + input_list_of_points[k][0]
                if 0 <= m < shape[0] and 0 <= n < shape[1]: vals.append(input_np_array[m, n])
            output[i, j] = min(vals)
    return output


@nb.jit(nopython=True)
def dilation(input_np_array, input_list_of_points, maximal_pixel_value=1):
    """
    Performs morphological dilation on a 2D array using Numba compilation and point offsets.

    Parameters
    ----------
    input_np_array : numpy.ndarray
        2D input array to dilate.
    input_list_of_points : list of numpy.ndarray or tuple
        Structuring element offsets.
    maximal_pixel_value : int or float, optional
        Maximum foreground value. Default is 1.

    Inputs
    ------
    - 2D image matrix and kernel points.

    Outputs
    -------
    - numpy.ndarray: Dilated 2D array.
    """
    shape = input_np_array.shape
    output = np.zeros(shape)
    for i in range(shape[0]):
        for j in range(shape[1]):
            if input_np_array[i, j] == maximal_pixel_value:
                output[i, j] = maximal_pixel_value
                continue
            vals = []
            for k in range(len(input_list_of_points)):
                m, n = i + input_list_of_points[k][1], j - input_list_of_points[k][0]
                if 0 <= m < shape[0] and 0 <= n < shape[1]: vals.append(input_np_array[m, n])
            output[i, j] = max(vals)
    return output


def opening(img, points):
    """
    Performs morphological opening (erosion followed by dilation).

    Parameters
    ----------
    img : numpy.ndarray
        Input 2D array.
    points : list
        Structuring element points.

    Inputs
    ------
    - 2D array and structuring element.

    Outputs
    -------
    - numpy.ndarray: Opened 2D array.
    """
    return dilation(erosion(img, points), points)


def closing(img, points):
    """
    Performs morphological closing (dilation followed by erosion).

    Parameters
    ----------
    img : numpy.ndarray
        Input 2D array.
    points : list
        Structuring element points.

    Inputs
    ------
    - 2D array and structuring element.

    Outputs
    -------
    - numpy.ndarray: Closed 2D array.
    """
    return erosion(dilation(img, points), points)


@nb.jit()
def get_rectangle_coordinates(arr):
    """
    Generates a list of 2D coordinates centered around an array shape.

    Parameters
    ----------
    arr : numpy.ndarray
        Template array.

    Inputs
    ------
    - Array dimensions.

    Outputs
    -------
    - list of numpy.ndarray: Centered coordinate offset vectors.
    """
    shape = np.shape(arr)
    return [np.array([int(shape[1] / 2) - j, int(shape[0] / 2) - i]) for i in range(shape[0]) for j in range(shape[1])]


def get_square_SE_list(maximal_SE_lengths):
    """
    Generates a list of square structuring element coordinate sets up to a max length.

    Parameters
    ----------
    maximal_SE_lengths : int
        Maximum structural element length.

    Inputs
    ------
    - Integer specifying size limit.

    Outputs
    -------
    - list: Collection of structuring element lists.
    """
    return [get_rectangle_coordinates(np.zeros((i, i))) for i in range(2, maximal_SE_lengths + 1)]


def persistence_of_img(img, maxdim=1):
    """
    Computes persistence diagrams of an image using Cripser.

    Parameters
    ----------
    img : numpy.ndarray
        Input image array.
    maxdim : int, optional
        Maximum homology dimension. Default is 1.

    Inputs
    ------
    - Numerical image array.

    Outputs
    -------
    - list: Homology persistence diagrams for dimension 0 and dimension 1.
    """
    img = np.asarray(img, dtype=np.float64)
    ph = cripser.compute_ph(img, maxdim=maxdim) if hasattr(cripser, "compute_ph") else cripser.computePH(img,
                                                                                                         maxdim=maxdim)
    return [ph[ph[:, 0] == 0][:, 1:3], ph[ph[:, 0] == 1][:, 1:3]]


def persistence_of_morph_filtration(img, kernel_list, morph_type='closing'):
    """
    Computes persistence diagrams across a morphological filtration sequence.

    Parameters
    ----------
    img : numpy.ndarray
        Input image array.
    kernel_list : list
        Sequence of structuring elements.
    morph_type : str, optional
        Morphological operation type. Default is 'closing'.

    Inputs
    ------
    - Image array and kernel list.

    Outputs
    -------
    - list: Persistence diagrams resulting from the filtration.
    """
    filtration = build_morph_filtration(
        img,
        kernel_list,
        morph_type
    )

    return persistence_of_img(filtration)


