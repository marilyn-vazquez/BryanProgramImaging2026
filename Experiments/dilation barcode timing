def run_ml_benchmark(df_data, output_dir):
    feature_cols = [f"Feature_{i + 1}" for i in range(10)]
    X_tda = df_data[feature_cols].values
    y = df_data["Label_Num"].values

    names = ["Linear SVM", "Neural Network (MLP)"]
    classifiers = [
        SVC(kernel="linear", C=1.0, random_state=42),
        MLPClassifier(hidden_layer_sizes=(32, 16), max_iter=1000, random_state=MLP_RANDOM_STATE)
    ]

    # Updated to utilize your specified 0.2 split
    X_train, X_test, y_train, y_test = train_test_split(X_tda, y, test_size=TEST_SIZE, random_state=SPLIT_SEED,
                                                        stratify=y)

    pca = PCA(n_components=2, random_state=42)
    X_train_vis = pca.fit_transform(X_train)

    fig = plt.figure(figsize=(10, 4))
    ax = plt.subplot(1, 3, 1)
    ax.set_title("Dilation PCA Data", fontsize=9, weight="bold")
    ax.scatter(X_train_vis[:, 0], X_train_vis[:, 1], c=y_train, cmap=ListedColormap(["#FF0000", "#0000FF"]),
               edgecolors="k", s=35)
    ax.set_xticks(());
    ax.set_yticks(())
    metrics_records = []

    for idx, (name, clf) in enumerate(zip(names, classifiers), start=2):

        ax = plt.subplot(1, 3, idx)

        # -------------------------
        # Time model training/testing
        # -------------------------
        t0 = perf_counter()

        model_pipeline = make_pipeline(
            StandardScaler(),
            clf
        )

        model_pipeline.fit(X_train, y_train)
        y_pred = model_pipeline.predict(X_test)

        t1 = perf_counter()

        acc = accuracy_score(y_test, y_pred)
        f1 = f1_score(y_test, y_pred, average="binary", zero_division=0)
        tn, fp, fn, tp = confusion_matrix(y_test, y_pred).ravel()

        metrics_records.append({
            "Model": name,
            "Training_Testing_Time_Sec": t1 - t0,
            "Accuracy": round(acc, 4),
            "F1-Score": round(f1, 4),
            "TN": tn,
            "FP": fp,
            "FN": fn,
            "TP": tp,
        })

        vis_pipeline = make_pipeline(
            StandardScaler(),
            copy.deepcopy(clf)
        )

        try:
            vis_pipeline.fit(X_train_vis, y_train)

            DecisionBoundaryDisplay.from_estimator(
                vis_pipeline,
                X_train_vis,
                cmap=mcm.RdBu,
                alpha=0.8,
                ax=ax,
                eps=0.5,
            )

            ax.scatter(
                X_train_vis[:, 0],
                X_train_vis[:, 1],
                c=y_train,
                cmap=ListedColormap(["#FF0000", "#0000FF"]),
                edgecolors="k",
                s=25,
            )

        except Exception as e:
            print(f"Skipping visualization for {name}: {e}")

        ax.set_title(f"{name}\nAcc: {acc:.2f}", fontsize=9, weight="bold")
        ax.set_xticks(())
        ax.set_yticks(())

    plt.tight_layout()
    plt.savefig(output_dir / "decision_boundaries.png", dpi=150)

    pd.DataFrame(metrics_records).to_csv(
        output_dir / "model_results.csv",
        index=False,
    )
    
def build_and_time_morph_dataset(image_paths, kernel_list, morph_type, output_root):

    ph_dir = output_root / "PH_Arrays"
    vec_dir = output_root / "Vectors"

    ph_dir.mkdir(parents=True, exist_ok=True)
    vec_dir.mkdir(parents=True, exist_ok=True)

    dataset_records = []
    timing_records = []

    for path in image_paths:

        img_id = path.stem[:-10] if path.stem.endswith("_processed") else path.stem

        label_num = 1 if "microgravity" in path.name.lower() else 0

        raw_img = img_as_float(io.imread(path, as_gray=True))
        binary_img = biImg_by_threshold_geq(raw_img, 0.5)

        # -----------------------------
        # Morphological filtration
        # -----------------------------
        t0 = perf_counter()

        filtration = build_morph_filtration(
            binary_img,
            kernel_list,
            morph_type
        )

        t1 = perf_counter()

        # -----------------------------
        # Persistent homology
        # -----------------------------
        pds = persistence_of_img(filtration)

        t2 = perf_counter()

        # -----------------------------
        # Vectorization
        # -----------------------------
        vec = extract_10d_barcode(pds)

        t3 = perf_counter()

        timing_records.append({
            "Image_ID": img_id,
            "Filtration_Time": t1 - t0,
            "Persistent_Homology_Time": t2 - t1,
            "Vectorization_Time": t3 - t2,
            "Total_Time": t3 - t0,
        })

        np.save(ph_dir / f"{img_id}_ph.npy", np.vstack(pds))
        np.save(vec_dir / f"{img_id}_vec.npy", vec)

        record = {
            "Image_ID": img_id,
            "Label_Num": label_num,
            "Label_Str": "Microgravity" if label_num else "Control",
            "Filtration_Name": FILTRATION_NAME,
            "Vectorization_Method": VECTORIZATION_METHOD,
            "Preprocessing_Version": PREPROCESSING_VERSION,
        }

        for i in range(10):
            record[f"Feature_{i+1}"] = vec[i]

        dataset_records.append(record)

    return pd.DataFrame(dataset_records), pd.DataFrame(timing_records)

