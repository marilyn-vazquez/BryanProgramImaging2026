def find(condition): return np.nonzero(condition)


def biImg_by_threshold_leq(img, threshold):
    output_img = np.copy(img)
    output_img[find(img <= threshold)], output_img[find(img > threshold)] = 0, 1
    return output_img


def biImg_by_threshold_geq(img, threshold):
    output_img = np.copy(img)
    output_img[find(img >= threshold)], output_img[find(img < threshold)] = 0, 1
    return output_img


@nb.jit(nopython=True)
def erosion(input_np_array, input_list_of_points, minimal_pixel_value=0):
    shape = input_np_array.shape
    output = np.zeros(shape)
    for i in range(shape[0]):
        for j in range(shape[1]):
            if input_np_array[i, j] == minimal_pixel_value:
                output[i, j] = minimal_pixel_value
                continue
            vals = []
            for k in range(len(input_list_of_points)):
                m, n = i - input_list_of_points[k][1], j + input_list_of_points[k][0]
                if 0 <= m < shape[0] and 0 <= n < shape[1]: vals.append(input_np_array[m, n])
            output[i, j] = min(vals)
    return output


@nb.jit(nopython=True)
def dilation(input_np_array, input_list_of_points, maximal_pixel_value=1):
    shape = input_np_array.shape
    output = np.zeros(shape)
    for i in range(shape[0]):
        for j in range(shape[1]):
            if input_np_array[i, j] == maximal_pixel_value:
                output[i, j] = maximal_pixel_value
                continue
            vals = []
            for k in range(len(input_list_of_points)):
                m, n = i + input_list_of_points[k][1], j - input_list_of_points[k][0]
                if 0 <= m < shape[0] and 0 <= n < shape[1]: vals.append(input_np_array[m, n])
            output[i, j] = max(vals)
    return output


def opening(img, points): return dilation(erosion(img, points), points)


def closing(img, points): return erosion(dilation(img, points), points)


@nb.jit()
def get_rectangle_coordinates(arr):
    shape = np.shape(arr)
    return [np.array([int(shape[1] / 2) - j, int(shape[0] / 2) - i]) for i in range(shape[0]) for j in range(shape[1])]



def get_square_SE_list(maximal_SE_lengths):
    return [get_rectangle_coordinates(np.zeros((i, i))) for i in range(2, maximal_SE_lengths + 1)]


def persistence_of_img(img, maxdim=1):
    img = np.asarray(img, dtype=np.float64)
    ph = cripser.compute_ph(img, maxdim=maxdim) if hasattr(cripser, "compute_ph") else cripser.computePH(img,
                                                                                                         maxdim=maxdim)
    return [ph[ph[:, 0] == 0][:, 1:3], ph[ph[:, 0] == 1][:, 1:3]]


def persistence_of_morph_filtration(img, kernel_list, morph_type='closing'):
    img_buff = np.zeros_like(img) + img
    for kernel in kernel_list:
        if morph_type == 'opening':
            morphed = opening(img, kernel)
        elif morph_type == 'closing':
            morphed = closing(img, kernel)
        elif morph_type == 'erosion':
            morphed = erosion(img, kernel)
        elif morph_type == 'dilation':
            morphed = dilation(img, kernel)
        else:
            raise ValueError("Invalid morph_type")
        img_buff += morphed
    return persistence_of_img(img_buff)


# =====================================================================
# 3. FEATURE EXTRACTION & PIPELINE RUNNERS
# =====================================================================
def extract_10d_barcode(pds):
    h0, h1 = pds
    combined = np.vstack([h0, h1]) if (len(h0) > 0 and len(h1) > 0) else (h0 if len(h0) > 0 else h1)
    if len(combined) == 0: return np.zeros(10)

    combined_finite = combined[np.isfinite(combined[:, 1])]
    births, deaths = combined_finite[:, 0], combined_finite[:, 1]
    persistence = deaths - births
    if len(persistence) == 0: return np.zeros(10)

    return np.array([
        np.mean(births), np.std(births), np.median(births), np.max(births),
        np.mean(deaths), np.std(deaths), np.max(deaths),
        np.mean(persistence), np.std(persistence), np.sum(persistence)
    ])


def build_morph_filtration(img, kernel_list, morph_type="closing"):
    img_buff = np.zeros_like(img) + img

    for kernel in kernel_list:

        if morph_type == "opening":
            morphed = opening(img, kernel)

        elif morph_type == "closing":
            morphed = closing(img, kernel)

        elif morph_type == "erosion":
            morphed = erosion(img, kernel)

        elif morph_type == "dilation":
            morphed = dilation(img, kernel)

        else:
            raise ValueError("Invalid morph_type")

        img_buff += morphed

    return img_buff
def persistence_of_morph_filtration(img, kernel_list, morph_type="closing"):

    filtration = build_morph_filtration(
        img,
        kernel_list,
        morph_type
    )

    return persistence_of_img(filtration)

