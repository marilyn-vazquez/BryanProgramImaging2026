def find(condition):
    """
    Finds the indices of elements that satisfy a given condition.

    Parameters
    ----------
    condition : array_like or bool
        Boolean array or condition expression to evaluate.

    Inputs
    ------
    - Array or conditional expression evaluated via `np.nonzero`.

    Outputs
    -------
    - tuple of ndarrays: Indices of elements where the condition is true.
    """
    return np.nonzero(condition)


def biImg_by_threshold_leq(img, threshold):
    """
    Converts a grayscale image into a binary image using a less-than-or-equal threshold rule.

    Parameters
    ----------
    img : numpy.ndarray
        Input grayscale image array.
    threshold : float or int
        Threshold cutoff value.

    Inputs
    ------
    - Pixel intensity array `img`.

    Outputs
    -------
    - numpy.ndarray: Binarized image array.
    """
    output_img = np.copy(img)

    idxs_0 = find(img <= threshold)
    idxs_1 = find(img > threshold)

    output_img[idxs_0] = 0
    output_img[idxs_1] = 1

    return output_img


@nb.jit(nopython=True)
def erosion(input_np_array, input_list_of_points, minimal_pixel_value=0):
    """
    Performs binary morphological erosion using a custom structuring element with Numba compilation.

    Parameters
    ----------
    input_np_array : numpy.ndarray
        2D input array to erode.
    input_list_of_points : list of numpy.ndarray or tuple
        Structuring element coordinate offsets.
    minimal_pixel_value : int or float, optional
        Minimum background value. Default is 0.

    Inputs
    ------
    - 2D image matrix and kernel point offsets.

    Outputs
    -------
    - numpy.ndarray: Eroded 2D array.
    """
    input_shape = input_np_array.shape
    output = np.zeros(input_shape)

    for i in range(input_shape[0]):
        for j in range(input_shape[1]):

            if input_np_array[i, j] == minimal_pixel_value:
                output[i, j] = minimal_pixel_value
                continue

            neighborhood = []

            for k in range(len(input_list_of_points)):

                m = i - input_list_of_points[k][1]
                n = j + input_list_of_points[k][0]

                if (
                    (m >= 0)
                    and (m < input_shape[0])
                    and (n >= 0)
                    and (n < input_shape[1])
                ):
                    neighborhood.append(input_np_array[m, n])

            output[i, j] = min(neighborhood)

    return output


@nb.jit()
def get_rectangle_coordinates(input_np_array):
    """
    Generates coordinate offsets describing a rectangular structuring element.

    Parameters
    ----------
    input_np_array : numpy.ndarray
        Template array representing the structuring element grid dimensions.

    Inputs
    ------
    - Template array dimensions.

    Outputs
    -------
    - list of numpy.ndarray: Centered coordinate offset vectors.
    """
    shape = np.shape(input_np_array)

    coords = []

    origin_i = int(shape[0] / 2)
    origin_j = int(shape[1] / 2)

    for i in range(shape[0]):
        for j in range(shape[1]):
            coords.append(np.array([origin_j - j, origin_i - i]))

    return coords


def get_square_SE_list(maximal_SE_lengths):
    """
    Creates square structuring elements ranging from 2x2 up to the specified maximum side length.

    Parameters
    ----------
    maximal_SE_lengths : int
        Maximum structural element side length.

    Inputs
    ------
    - Integer specifying size limit.

    Outputs
    -------
    - list: Collection of structuring element lists.
    """
    kernel_list = []

    for size in range(2, maximal_SE_lengths + 1):
        kernel_list.append(
            get_rectangle_coordinates(
                np.zeros((size, size))
            )
        )

    return kernel_list


def persistence_of_img(img, maxdim=1):
    """
    Computes persistent homology of an image using Cripser, returning H0 and H1 diagrams separately.

    Parameters
    ----------
    img : numpy.ndarray
        Input image array.
    maxdim : int, optional
        Maximum homology dimension. Default is 1.

    Inputs
    ------
    - Numerical image array.

    Outputs
    -------
    - list: Homology persistence diagrams for dimension 0 and dimension 1.
    """

    img = np.asarray(img, dtype=np.float64)

    if hasattr(cripser, "compute_ph"):
        ph = cripser.compute_ph(img, maxdim=maxdim)
    else:
        ph = cripser.computePH(img, maxdim=maxdim)

    persistence_0 = ph[ph[:, 0] == 0][:, 1:3]
    persistence_1 = ph[ph[:, 0] == 1][:, 1:3]

    return [persistence_0, persistence_1]


def compute_erosion_filtration(binary_img, kernel_list):
    """
    Builds the cumulative erosion filtration stack.

    Parameters
    ----------
    binary_img : numpy.ndarray
        Binary image array.
    kernel_list : list
        Sequence of structuring elements.

    Inputs
    ------
    - Binary image and kernel sequence.

    Outputs
    -------
    - numpy.ndarray: Cumulative filtration accumulation image.
    """

    img_buffer = np.array(binary_img, dtype=np.float64)

    for kernel in kernel_list:

        eroded = erosion(
            input_np_array=binary_img,
            input_list_of_points=kernel
        )

        img_buffer += eroded

    return img_buffer


def vectorize_persistence_diagram(pds):
    """
    Converts persistence diagrams into a 10-dimensional summary feature vector.

    Parameters
    ----------
    pds : list of numpy.ndarray
        Persistence diagram arrays for H0 and H1.

    Inputs
    ------
    - Birth-death persistence pairs.

    Outputs
    -------
    - numpy.ndarray: 10D statistical feature vector.
    """

    h0, h1 = pds

    if len(h0) > 0 and len(h1) > 0:
        combined = np.vstack([h0, h1])
    elif len(h0) > 0:
        combined = h0
    elif len(h1) > 0:
        combined = h1
    else:
        return np.zeros(10, dtype=np.float64)

    finite = np.isfinite(combined[:, 1])
    combined = combined[finite]

    if len(combined) == 0:
        return np.zeros(10, dtype=np.float64)

    births = combined[:, 0]
    deaths = combined[:, 1]
    persistence = deaths - births

    if len(persistence) == 0:
        return np.zeros(10, dtype=np.float64)

    feature_vector = np.array([
        np.mean(births),
        np.std(births),
        np.median(births),
        np.max(births),

        np.mean(deaths),
        np.std(deaths),
        np.max(deaths),

        np.mean(persistence),
        np.std(persistence),
        np.sum(persistence)
    ], dtype=np.float64)

    return np.nan_to_num(
        feature_vector,
        nan=0.0,
        posinf=0.0,
        neginf=0.0
    )


def get_image_id(image_path):
    """
    Removes the file extension and trailing '_processed' from the filename.

    Parameters
    ----------
    image_path : str or pathlib.Path
        Path to the image file.

    Inputs
    ------
    - Image file path.

    Outputs
    -------
    - str: Cleaned image identifier string.
    """
    image_id = Path(image_path).stem

    if image_id.lower().endswith("_processed"):
        image_id = image_id[:-10]

    return image_id


def get_label_from_filename(image_path):
    """
    Determines class label and string descriptor from filename.

    Parameters
    ----------
    image_path : str or pathlib.Path
        Path to the image file.

    Inputs
    ------
    - Image file path.

    Outputs
    -------
    - tuple: Numeric label (int) and string label (str).
    """

    filename = Path(image_path).name.lower()

    if "microgravity" in filename:
        return 1, "Microgravity"

    if "control" in filename:
        return 0, "Control"

    raise ValueError(
        f"Could not determine class label from {image_path}"
    )


def build_and_time_erosion_dataset(
        image_paths,
        ph_output_dir,
        image_vector_output_dir,
        filtration_name,
        vectorization_method,
        preprocessing_version,
        save_recomputed_ph=True,
):
    """
    Computes erosion persistence diagrams, feature vectors, and execution timings for every image.

    Parameters
    ----------
    image_paths : list of pathlib.Path or str
        Collection of image paths.
    ph_output_dir : str or pathlib.Path
        Directory to store persistence diagram arrays.
    image_vector_output_dir : str or pathlib.Path
        Directory to store vector arrays.
    filtration_name : str
        Name of the filtration technique.
    vectorization_method : str
        Name of the vectorization method.
    preprocessing_version : str
        Version identifier for preprocessing.
    save_recomputed_ph : bool, optional
        Whether to save persistence diagram files to disk. Default is True.

    Inputs
    ------
    - Image file paths and experiment configuration settings.

    Outputs
    -------
    - tuple of pandas.DataFrame: Dataset records DataFrame and timing logs DataFrame.
    """

    os.makedirs(ph_output_dir, exist_ok=True)
    os.makedirs(image_vector_output_dir, exist_ok=True)

    dataset_records = []
    timing_records = []

    kernels = get_square_SE_list(maximal_SE_lengths=4)

    for path in image_paths:

        image_id = get_image_id(path)

        label_num, label_str = get_label_from_filename(path)

        # ----------------------------
        # Load image
        # ----------------------------
        img = img_as_float(
            io.imread(path, as_gray=True)
        )

        # ----------------------------
        # Stage 1: Binary threshold
        # ----------------------------
        t0 = perf_counter()

        binary_img = biImg_by_threshold_leq(
            img,
            threshold=0.5
        )

        t1 = perf_counter()

        # ----------------------------
        # Stage 2: Build filtration
        # ----------------------------
        filtration = compute_erosion_filtration(
            binary_img,
            kernels
        )

        t2 = perf_counter()

        # ----------------------------
        # Stage 3: Persistent homology
        # ----------------------------
        pds = persistence_of_img(filtration)

        t3 = perf_counter()

        # ----------------------------
        # Stage 4: Vectorization
        # ----------------------------
        feature_vector = vectorize_persistence_diagram(
            pds
        )

        t4 = perf_counter()
        # ----------------------------
        # Record timing
        # ----------------------------
        timing_records.append({

            "Image_ID": image_id,

            "Threshold_Time": t1 - t0,

            "Filtration_Time": t2 - t1,

            "PH_Time": t3 - t2,

            "Vectorization_Time": t4 - t3,

            "Total_Time": t4 - t0
        })

        # ----------------------------
        # Save outputs
        # ----------------------------
        if save_recomputed_ph:

            np.save(
                os.path.join(
                    ph_output_dir,
                    f"{image_id}_ph.npy"
                ),
                np.array(
                    pds,
                    dtype=object
                ),
                allow_pickle=True
            )

        np.save(
            os.path.join(
                image_vector_output_dir,
                f"{image_id}_vec.npy"
            ),
            feature_vector
        )

        # ----------------------------
        # Build dataset record
        # ----------------------------
        record = {

            "Image_ID": image_id,
            "Label_Num": label_num,
            "Label_Str": label_str,

            "Filtration_Name":
                filtration_name,

            "Vectorization_Method":
                vectorization_method,

            "Preprocessing_Version":
                preprocessing_version
        }

        for i in range(10):
            record[f"Feature_{i+1}"] = feature_vector[i]

        dataset_records.append(record)

    return (
        pd.DataFrame(dataset_records),
        pd.DataFrame(timing_records)
    )


def evaluate_model(model, name, X_train, X_test, y_train, y_test):
    """
    Trains and evaluates a machine learning model pipeline.

    Parameters
    ----------
    model : estimator object
        Unfitted scikit-learn model instance.
    name : str
        Model descriptor name.
    X_train : numpy.ndarray
        Training feature matrix.
    X_test : numpy.ndarray
        Testing feature matrix.
    y_train : numpy.ndarray
        Training target labels.
    y_test : numpy.ndarray
        Testing target labels.

    Inputs
    ------
    - Model estimator, name, and split feature/target datasets.

    Outputs
    -------
    - dict: Evaluation metrics dictionary including execution time, accuracy, F1-score, and confusion matrix.
    """

    t0 = perf_counter()

    pipeline = make_pipeline(
        StandardScaler(),
        model
    )

    pipeline.fit(X_train, y_train)

    predictions = pipeline.predict(X_test)

    t1 = perf_counter()

    tn, fp, fn, tp = confusion_matrix(
        y_test,
        predictions
    ).ravel()

    return {

        "Model": name,

        "Training_Testing_Time_Sec": t1 - t0,

        "Accuracy": accuracy_score(
            y_test,
            predictions
        ),

        "F1_Score": f1_score(
            y_test,
            predictions
        ),

        "TN": tn,
        "FP": fp,
        "FN": fn,
        "TP": tp
    }


def run_experiment(image_paths, output_root):
    """
    Executes the complete erosion topological data analysis experiment pipeline.

    Parameters
    ----------
    image_paths : list of pathlib.Path or str
        Collection of processed image paths.
    output_root : str or pathlib.Path
        Output directory path to store CSV reports and features.

    Inputs
    ------
    - Image paths and output root directory.

    Outputs
    -------
    - Disk files: dataset.csv, image_timing.csv, timing_summary.csv, and model_results.csv.
    """

    ph_dir = os.path.join(
        output_root,
        "PH_Arrays"
    )

    vec_dir = os.path.join(
        output_root,
        "Vectors"
    )

    # ------------------------------------------------------------
    # Build feature dataset
    # ------------------------------------------------------------
    df_data, df_times = build_and_time_erosion_dataset(

        image_paths=image_paths,

        ph_output_dir=ph_dir,

        image_vector_output_dir=vec_dir,

        filtration_name=FILTRATION_NAME,

        vectorization_method=VECTORIZATION_METHOD,

        preprocessing_version=PREPROCESSING_VERSION,

        save_recomputed_ph=SAVE_RECOMPUTED_PH,
    )

    # ------------------------------------------------------------
    # Save dataset and timing information
    # ------------------------------------------------------------
    df_data.to_csv(
        os.path.join(output_root, "dataset.csv"),
        index=False
    )

    df_times.to_csv(
        os.path.join(output_root, "image_timing.csv"),
        index=False
    )

    df_times.describe().to_csv(
        os.path.join(output_root, "timing_summary.csv")
    )

    # ------------------------------------------------------------
    # Prepare ML dataset
    # ------------------------------------------------------------
    feature_columns = [
        f"Feature_{i+1}"
        for i in range(10)
    ]

    X = df_data[feature_columns].values

    y = df_data["Label_Num"].values

    X_train, X_test, y_train, y_test = train_test_split(

        X,

        y,

        test_size=TEST_SIZE,

        random_state=SPLIT_SEED,

        stratify=y
    )

    # ------------------------------------------------------------
    # Models
    # ------------------------------------------------------------
    models = [

        (
            SVC(
                kernel="linear"
            ),
            "Linear_SVM"
        ),

        (
            SVC(
                kernel="rbf"
            ),
            "RBF_SVM"
        ),

        (
            MLPClassifier(
                random_state=MLP_RANDOM_STATE,
                max_iter=1000
            ),
            "Neural_Network"
        )
    ]

    results = []

    for model, name in models:

        results.append(

            evaluate_model(

                model,

                name,

                X_train,

                X_test,

                y_train,

                y_test

            )
        )

    pd.DataFrame(results).to_csv(

        os.path.join(

            output_root,

            "model_results.csv"

        ),

        index=False
    )

    print("\nExperiment Complete\n")

    print(pd.DataFrame(results))


